{
  "name": "@f1-hub/collector",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "sh -c 'pnpm run dev:writer & pnpm run dev:ingest && wait'",
    "start": "sh -c 'pnpm run start:writer & pnpm run start:ingest && wait'",
    "dev:ingest": "tsx watch src/ingest.ts",
    "dev:writer": "tsx watch src/writer.ts",
    "start:ingest": "tsx src/ingest.ts",
    "start:writer": "tsx src/writer.ts",
    "seed:sessions": "tsx src/seed-sessions.ts",
    "bootstrap:australia:local": "tsx src/bootstrap-australia-local.ts",
    "backfill:track": "tsx src/backfill-track.ts",
    "backfill:replay": "tsx src/backfill-replay.ts",
    "backfill:replay:openf1": "tsx src/backfill-replay-openf1.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "echo 'lint not configured yet'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@f1-hub/contracts": "workspace:*",
    "@f1-hub/data": "workspace:*",
    "dotenv": "17.2.3",
    "prom-client": "^15.1.3",
    "redis": "^5.11.0",
    "ws": "8.18.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.7.2",
    "@types/ws": "8.18.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
